# Aggregate per-barcode read counts from demux FASTQs and dupsifter stats
rule qc_barcode_counts:
    input:
        dmux_done = "pipeline_output/{sample}/dmux/_merged_done.flag",
        align_txt = "pipeline_output/{sample}/dmux/align_list.txt",
    output:
        counts = "qc_output/{sample}/table/{sample}_barcode_counts.tsv",
    resources:
        mem = "8G",
        cpus_per_task = 4,
    shell:
        """
        mkdir -p qc_output/{wildcards.sample}/table/
        {PYTHON} {workflow.basedir}/qc/count_barcodes.py \
            --dmux-dir pipeline_output/{wildcards.sample}/dmux/ \
            --bam-dir  pipeline_output/{wildcards.sample}/bam/ \
            --sample   {wildcards.sample} \
            --output-dir qc_output/{wildcards.sample}/table/
        """

# Map per-barcode counts to 2D spatial coordinates using the barcode whitelist
rule qc_spatial_match:
    input:
        counts    = "qc_output/{sample}/table/{sample}_barcode_counts.tsv",
        whitelist = "barcodes/spatial_barcodes.txt",
    output:
        spatial_counts = "qc_output/{sample}/table/{sample}_spatial_barcode_counts.tsv",
        bool_index     = "qc_output/{sample}/table/{sample}_barcodes_bool_index.tsv",
    resources:
        mem = "4G",
        cpus_per_task = 1,
    shell:
        """
        {PYTHON} {workflow.basedir}/qc/match_barcodes.py \
            --barcode-counts {input.counts} \
            --whitelist      {input.whitelist} \
            --sample         {wildcards.sample} \
            --output-dir     qc_output/{wildcards.sample}/table/
        """

# Generate spatial heatmap PNGs (DNA counts, mapping rate, dup rate)
rule qc_spatial_plots:
    input:
        spatial_counts = "qc_output/{sample}/table/{sample}_spatial_barcode_counts.tsv",
    output:
        flag = "qc_output/{sample}/plots/.done",
    resources:
        mem = "8G",
        cpus_per_task = 1,
    shell:
        """
        mkdir -p qc_output/{wildcards.sample}/plots/
        {PYTHON} {workflow.basedir}/qc/plot_spatial_qc.py \
            --spatial-counts {input.spatial_counts} \
            --sample         {wildcards.sample} \
            --output-dir     qc_output/{wildcards.sample}/plots/
        touch {output.flag}
        """

# Run MultiQC over all pipeline outputs for this sample
rule qc_multiqc:
    input:
        star_log    = "pipeline_output/{sample}/rna_processed/align/Log.final.out",
        plots_flag  = "qc_output/{sample}/plots/.done",
    output:
        report = "qc_output/{sample}/multiqc_report.html",
    resources:
        mem = "8G",
        cpus_per_task = 1,
    shell:
        """
        {PYTHON} -m multiqc pipeline_output/{wildcards.sample}/ \
            --outdir qc_output/{wildcards.sample}/ \
            --filename multiqc_report.html \
            --force
        """

# Generate self-contained HTML report with embedded spatial plots and summary stats
rule qc_html_report:
    input:
        spatial_counts = "qc_output/{sample}/table/{sample}_spatial_barcode_counts.tsv",
        plots_flag     = "qc_output/{sample}/plots/.done",
        multiqc        = "qc_output/{sample}/multiqc_report.html",
    output:
        report = "qc_output/{sample}/qc_report.html",
    resources:
        mem = "4G",
        cpus_per_task = 1,
    shell:
        """
        {PYTHON} {workflow.basedir}/qc/generate_html_report.py \
            --spatial-counts {input.spatial_counts} \
            --plots-dir      qc_output/{wildcards.sample}/plots/ \
            --sample         {wildcards.sample} \
            --multiqc-html   {input.multiqc} \
            --output         {output.report}
        """

# Top-level QC target: produces both the spatial HTML report and MultiQC for all samples
rule qc:
    input:
        expand("qc_output/{sample}/qc_report.html", sample=SAMPLES),

# Run with: snakemake --profile profiles/local_HPC --snakefile Data_preprocess/Snakefile -- clean
rule clean:
    run:
        import shutil
        for sample in SAMPLES:
            for d in [
                os.path.join("pipeline_output", sample, "tmp"),
                os.path.join("qc_output", sample, "plots"),
            ]:
                if os.path.exists(d):
                    shutil.rmtree(d)
                    print(f"Removed {d}")
