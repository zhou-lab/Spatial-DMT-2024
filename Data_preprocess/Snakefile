    output:
        flag = "qc_output/{sample}/plots/.done",
    resources:
        mem = "8G",
        cpus_per_task = 1,
    shell:
        """
        mkdir -p qc_output/{wildcards.sample}/plots/
        {PYTHON} {workflow.basedir}/qc/plot_spatial_qc.py \
            --spatial-counts {input.spatial_counts} \
            --sample         {wildcards.sample} \
            --output-dir     qc_output/{wildcards.sample}/plots/
        touch {output.flag}
        """

# MultiQC: aggregates STAR logs, bbduk stats, and BISCUIT QC tables
rule qc_multiqc:
    input:
        star_log   = "pipeline_output/{sample}/rna_processed/align/Log.final.out",
        biscuit_qc = "pipeline_output/{sample}/biscuit_qc/.done",
        plots_flag = "qc_output/{sample}/plots/.done",
    output:
        report = "qc_output/{sample}/multiqc_report.html",
    resources:
        mem = "8G",
        cpus_per_task = 1,
    shell:
        """
        {PYTHON} -m multiqc \
            pipeline_output/{wildcards.sample}/ \
            --outdir qc_output/{wildcards.sample}/ \
            --filename multiqc_report.html \
            --force
        """

# Self-contained HTML report with embedded spatial plots and summary stats
rule qc_html_report:
    input:
        spatial_counts = "qc_output/{sample}/table/{sample}_spatial_barcode_counts.tsv",
        plots_flag     = "qc_output/{sample}/plots/.done",
        multiqc        = "qc_output/{sample}/multiqc_report.html",
    output:
        report = "qc_output/{sample}/qc_report.html",
    resources:
        mem = "4G",
        cpus_per_task = 1,
    shell:
        """
        {PYTHON} {workflow.basedir}/qc/generate_html_report.py \
            --spatial-counts {input.spatial_counts} \
            --plots-dir      qc_output/{wildcards.sample}/plots/ \
            --sample         {wildcards.sample} \
            --multiqc-html   {input.multiqc} \
            --output         {output.report}
        """

# Per-barcode mean methylation summarized over genomic features (ChromHMM, windows, chromosomes)
rule feature_mean:
    input:
        cg   = "pipeline_output/{sample}/pileup/{sample}.cg",
        feat = os.path.join(FEATURE_DIR, "{feat}.bed.gz"),
    output:
        txt = "pipeline_output/{sample}/features/{feat}.txt.gz",
    resources:
        mem = "120G",
        time = "6:00:00",
        cpus_per_task = 24,
    shell:
        """
        set -xe
        tmp=pipeline_output/{wildcards.sample}/tmp/features_{wildcards.feat}/
        rm -rf $tmp && mkdir -p $tmp
        cut -f1 {input.cg}.idx | parallel -j {resources.cpus_per_task} \
            'yame subset {input.cg} {{}} | \
                yame summary -q {{}} -m {FEATURE_CM_DIR}/{wildcards.feat}.cm - | \
                gzip -c > '"$tmp"'/{{}}. txt.gz'
        zcat $tmp/*.txt.gz | awk 'NR==1 || $1 != "QFile"' | gzip -c > {output.txt}
        rm -rf $tmp
        """

# QC target: spatial HTML report + MultiQC + feature-level methylation summaries
rule qc:
    input:
        expand("qc_output/{sample}/qc_report.html", sample=SAMPLES),
        expand("pipeline_output/{sample}/features/{feat}.txt.gz", sample=SAMPLES, feat=FEATS),

################################################################################
# Clean
# NOTE: run allc target before clean — clean removes tmp/ pileup VCFs needed by allc.
################################################################################

rule clean:
    run:
        import shutil
        for sample in SAMPLES:
            for d in [
                os.path.join("pipeline_output", sample, "tmp"),
                os.path.join("qc_output", sample, "plots"),
            ]:
                if os.path.exists(d):
                    shutil.rmtree(d)
                    print(f"Removed {d}")

################################################################################
# AllC Rules
# Run after preprocessing (before clean): snakemake --profile profiles/local_HPC -- allc
################################################################################

FEATS_CH = ["TrinucCHxChromHMM.20220414", "GeneCAC.20220322", "Dinuc.20231030", "TrinucCH.20220321"]

# All-cytosine pileup packed into yame .allc format; enables non-CpG methylation analysis.
rule biscuit_pileup_allc:
    input:
        cg = "pipeline_output/{sample}/pileup/{sample}.cg",
    output:
        allc = "pipeline_output/{sample}/pileup/{sample}.allc",
    resources:
        mem = "250G",
        time = "168:00:00",
        cpus_per_task = 15,
    params:
        ref_fasta = os.path.join(REF_DIR, ref["REF_BASE"], ref["REF_FASTA"]),
        allc_bed  = os.path.join(REF_DIR, ref["REF_BASE"], ref["ALLC_BED"]),
    shell:
        """
        set -xe
        tmp_pileup=pipeline_output/{wildcards.sample}/tmp/pileup/

        BetaCov2MU() {{
            awk -F"\t" -v OFS="\t" -f {workflow.basedir}/../tools/wanding.awk \
                -e '$4=="."{{print 0,0;next;}}{{M=round($4*$5); print M,$5-M;}}' $1;
        }}
        export -f BetaCov2MU

        find $tmp_pileup -name '*.vcf.gz' | parallel -j {resources.cpus_per_task} '
            barcode=$(basename {{}} .vcf.gz)
            biscuit vcf2bed -k 1 -t c {{}} | \
                LC_ALL=C sort -k1,1 -k2,2n -T $tmp_pileup > $tmp_pileup/allc_$barcode.bed
            bedtools intersect -a {params.allc_bed} -b $tmp_pileup/allc_$barcode.bed -sorted -loj | \
                cut -f1,2,3,10,11 | BetaCov2MU | yame pack -f 3 - > $tmp_pileup/$barcode.allc
            rm -f $tmp_pileup/allc_$barcode.bed
        '

        :>{output.allc}
        for f in $tmp_pileup/*.allc; do
            barcode=$(basename $f .allc)
            cat $f >> {output.allc}
            yame index -1 $barcode {output.allc}
        done
        """

# Per-barcode mean non-CpG methylation summarized over genomic features.
rule feature_mean_allc:
    input:
        allc = "pipeline_output/{sample}/pileup/{sample}.allc",
        feat = os.path.join(FEATURE_DIR, "{feat}.bed.gz"),
    output:
        txt = "pipeline_output/{sample}/features_allc/{feat}.txt.gz",
    resources:
        mem = "150G",
        time = "72:00:00",
        cpus_per_task = 24,
    shell:
        """
        set -xe
        tmp=pipeline_output/{wildcards.sample}/tmp/features_allc_{wildcards.feat}/
        rm -rf $tmp && mkdir -p $tmp
        tmp_pileup=pipeline_output/{wildcards.sample}/tmp/pileup/

        tallyGroup() {{
            awk -v barcode=$2 -v OFS="\t" -F"\t" \
                '{{cnt[$2]+=1; sum[$2]+=$1;}}
                 END{{for(k in cnt){{print k, sum[k]/cnt[k], cnt[k], "{wildcards.sample}", barcode;}}}}' $1
        }}
        export -f tallyGroup

        find $tmp_pileup -name '*.vcf.gz' | parallel -j {resources.cpus_per_task} '
            barcode=$(basename {{}} .vcf.gz)
            biscuit vcf2bed -k 1 -t c {{}} | \
                bedtools intersect -a - -b {input.feat} -sorted -wo | \
                cut -f4,9 | tallyGroup - "$barcode" | sort -k1,1 \
                > '"$tmp"'/$barcode.tmp
        '
        cat $tmp/*.tmp | gzip -c > {output.txt}
        rm -rf $tmp
        """

# AllC target: all-cytosine pileup and non-CpG feature summaries
rule allc:
    input:
        expand("pipeline_output/{sample}/pileup/{sample}.allc", sample=SAMPLES),
        expand("pipeline_output/{sample}/features_allc/{feat}.txt.gz", sample=SAMPLES, feat=FEATS_CH),
