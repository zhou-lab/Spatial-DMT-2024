import os
import glob

# Resolve the genome-specific ref dict from site.yaml using the 'ref' config key
target_ref = config.get("ref", "")
if target_ref in config:
    ref = config[target_ref]
elif target_ref:
    raise ValueError(f"Genome reference '{target_ref}' not found in genomes.yaml.")
else:
    ref = {}

GENOME = config.get("ref", "unknown")

# Normalize genome to the top-level subdirectory used in REF_DIR
if GENOME.startswith("hg38"):
    GENOME_FOR_PATH = "hg38"
elif GENOME.startswith("mm10"):
    GENOME_FOR_PATH = "mm10"
else:
    raise ValueError(f"Unsupported genome: {GENOME}. Must be hg38 or mm10 based.")

# Configurable I/O roots. Defaults preserve the original cwd-relative behavior.
# Override via --config WORKDIR=... OUTDIR=... FASTQ_DIR=... or set in profile config.
FASTQ_DIR = config.get("FASTQ_DIR", "fastq")
WORKDIR   = config.get("WORKDIR",   "pipeline_output")
OUTDIR    = config.get("OUTDIR",    "final_output")

# Discover samples: explicit IDS list or auto-detect from {FASTQ_DIR}/*/DNA_1.fq* on disk
if "IDS" in config:
    SAMPLES = config["IDS"].split(",")
else:
    DNA_FILES = glob.glob(os.path.join(FASTQ_DIR, "*/DNA_1.fq*"))
    SAMPLES = sorted(list(set([os.path.dirname(f).split(os.sep)[-1] for f in DNA_FILES])))

RNA_SAMPLES = [s for s in SAMPLES if any(
    os.path.exists(os.path.join(FASTQ_DIR, s, f"RNA_1{ext}"))
    for ext in [".fq.gz", ".fq", ".fastq.gz", ".fastq"]
)]
print(f"Detected samples: {SAMPLES} in {FASTQ_DIR}/ ({len(RNA_SAMPLES)} with RNA)")

def require_config(key):
    if key not in config:
        raise ValueError(
            f"Required config key '{key}' is missing. "
            f"Set it in your profile config.yaml or via --config {key}=..."
        )
    return config[key]

REF_DIR      = require_config("REF_DIR")
PYTHON       = require_config("PYTHON")
BARCODES_DIR = os.path.join(workflow.basedir, "..", "barcodes")

## R2 chemistry: spatialdmt (50x50, 8+8bp barcodes — default)
##           or smcseq (96x96, 11+11bp + GGTGTAGTGGGTTTGGAGG primer)
PROTOCOL = config.get("protocol", "spatialdmt")
if PROTOCOL == "smcseq":
    BARCODE_WHITELIST = os.path.join(BARCODES_DIR, "smcseq_barcodes_22mer.txt")
    BARCODE_WL_COL    = 1
elif PROTOCOL == "spatialdmt":
    BARCODE_WHITELIST = os.path.join(BARCODES_DIR, "spatial_barcodes.txt")
    BARCODE_WL_COL    = 4
else:
    raise ValueError(f"Unknown protocol '{PROTOCOL}'. Expected spatialdmt or smcseq.")

def _grid_dims(path):
    """Derive (max X, max Y) from whitelist cols 2 and 3 (1-indexed)."""
    mx = my = 0
    with open(path) as f:
        for line in f:
            parts = line.rstrip("\n").split("\t")
            if len(parts) >= 3 and parts[1].isdigit() and parts[2].isdigit():
                mx = max(mx, int(parts[1]))
                my = max(my, int(parts[2]))
    return mx, my

GRID_X, GRID_Y = _grid_dims(BARCODE_WHITELIST)

# Resolve input fastq path, supporting .fq/.fastq with or without .gz
def get_fastq(wildcards, prefix):
    sample_dir = os.path.join(FASTQ_DIR, wildcards.sample)
    for ext in [".fq.gz", ".fq", ".fastq.gz", ".fastq"]:
        path = os.path.join(sample_dir, prefix + ext)
        if os.path.exists(path):
            return path
    return os.path.join(sample_dir, prefix + ".fq")

# Main entry point: run preprocessing, QC, and collect deliverables in {OUTDIR}/
rule final_output:
    input:
        expand(WORKDIR + "/{sample}/pileup/{sample}.cg", sample=SAMPLES),
        expand(WORKDIR + "/{sample}/pileup/{sample}_Lambda.cg", sample=SAMPLES),
        expand(WORKDIR + "/{sample}/rna_STAR/Aligned.out.sam", sample=RNA_SAMPLES),
        expand(WORKDIR + "/{sample}/qc/html/qc_report.html", sample=SAMPLES),
        expand(OUTDIR + "/{sample}/{sample}.cg", sample=SAMPLES),
        expand(OUTDIR + "/{sample}/{sample}.cg.idx", sample=SAMPLES),
        expand(OUTDIR + "/{sample}/{sample}_Lambda.cg", sample=SAMPLES),
        expand(OUTDIR + "/{sample}/qc_report.html", sample=SAMPLES),
        expand(OUTDIR + "/{sample}/multiqc_report.html", sample=SAMPLES),
        expand(OUTDIR + "/{sample}/multiqc_report_data", sample=SAMPLES),
        expand(OUTDIR + "/{sample}/Solo.out", sample=RNA_SAMPLES),

################################################################################
# DNA Pipeline Rules
################################################################################

## Demux-after-align architecture (smcseq + spatialdmt):
##   1. dna_trim_and_tag: rewrite each read name as <origid>_<XXYY>_<UMI>;
##      emit a single tagged R1/R2 pair per sample (no per-cell shards).
##   2. dna_biscuit_align: one biscuit align -9 → dupsifter -B (cell-aware,
##      BS-correct) → samtools sort → split BAM by CB:Z tag into bam/XXYY.bam
##      (the 0000 cell holds reads whose barcode missed the whitelist; renamed
##      to bam/UNMATCHED.bam for back-compat with downstream QC rules).
##   3. dna_biscuit_pileup: per-cell pileup over bam/*.bam (unchanged).
##
## Replaces the original demux-before-align path which spawned ~9216 biscuit
## invocations per sample.
DUPSIFTER = config.get("DUPSIFTER", "/home/zhouw3/software/dupsifter/v1.3.0/bin/dupsifter")
SPLIT_BAM_BY_CB = os.path.join(workflow.basedir, "..", "tools", "split_bam_by_cb.py")

## Lambda fastq outputs only exist for spatialdmt -- smcseq has no dedicated
## lambda barcode, so spatialmeth_trimtag.py doesn't write per-chunk Lambda
## fastqs and the cat block is skipped (see _LAMBDA_CAT_BLOCK below).
_TRIM_LAMBDA_OUTS = {}
_LAMBDA_CAT_BLOCK = ""
if PROTOCOL == "spatialdmt":
    _TRIM_LAMBDA_OUTS = {
        "lambda_r1": WORKDIR + "/{sample}/trim/{sample}_Lambda_R1.fq.gz",
        "lambda_r2": WORKDIR + "/{sample}/trim/{sample}_Lambda_R2.fq.gz",
    }
    _LAMBDA_CAT_BLOCK = """
        :> {output.lambda_r1}; :> {output.lambda_r2}
        for f in $(/bin/ls {WORKDIR}/{wildcards.sample}/tmp/trim/_out_*_Lambda_R1.fq.gz | sort -V); do
            cat "$f" >> {output.lambda_r1}
            cat "${{f%_Lambda_R1.fq.gz}}_Lambda_R2.fq.gz" >> {output.lambda_r2}
        done"""

rule dna_trim_and_tag:
    input:
        r1 = lambda wildcards: get_fastq(wildcards, "DNA_1"),
        r2 = lambda wildcards: get_fastq(wildcards, "DNA_2"),
        wl = BARCODE_WHITELIST,
    output:
        r1_out    = WORKDIR + "/{sample}/trim/{sample}_R1.fq.gz",
        r2_out    = WORKDIR + "/{sample}/trim/{sample}_R2.fq.gz",
        stats     = WORKDIR + "/{sample}/trim/{sample}_trim_stats.txt",
        **_TRIM_LAMBDA_OUTS,
    resources:
        mem = "140G",
        time = "120:00:00",
        cpus_per_task = 24,
    shell:
        """
        set -xeo pipefail
        mkdir -p {WORKDIR}/{wildcards.sample}/trim/ \
                 {WORKDIR}/{wildcards.sample}/tmp/trim/

        CAT_CMD1="cat"
        if [[ {input.r1} == *.gz ]]; then CAT_CMD1="pigz -dc"; fi
        CAT_CMD2="cat"
        if [[ {input.r2} == *.gz ]]; then CAT_CMD2="pigz -dc"; fi

        $CAT_CMD1 {input.r1} | split -d -a 4 -l 40000000 - {WORKDIR}/{wildcards.sample}/tmp/trim/_chunk_1
        $CAT_CMD2 {input.r2} | split -d -a 4 -l 40000000 - {WORKDIR}/{wildcards.sample}/tmp/trim/_chunk_2

        parallel --halt soon,fail=1 -j {resources.cpus_per_task} '
            f={{}}; b=$(basename "$f"); cid=${{b#_chunk_1}}
            d=$(dirname "$f"); f2="$d/_chunk_2$cid"
            {PYTHON} {workflow.basedir}/../tools/spatialmeth_trimtag.py \
                "$f" "$f2" \
                -o {WORKDIR}/{wildcards.sample}/tmp/trim/_out_"$cid" \
                -a CTATCTCTTATA AGATGCGAGAAGCCAACGCTTG \
                    AATCATACACCAATACAAAACATCAACCAC \
                    CAAATACTCTAACCTCTCAAACACATAAAT \
                --protocol {PROTOCOL} \
                --whitelist {input.wl} \
                --whitelist_col {BARCODE_WL_COL} \
                --bc-mismatch 1
        ' ::: {WORKDIR}/{wildcards.sample}/tmp/trim/_chunk_1*

        ## Cat per-chunk gzipped outputs (gzip concat is valid; readers stream through)
        :> {output.r1_out}; :> {output.r2_out}
        for f in $(/bin/ls {WORKDIR}/{wildcards.sample}/tmp/trim/_out_[0-9][0-9][0-9][0-9]_R1.fq.gz | sort -V); do
            cat "$f" >> {output.r1_out}
            cat "${{f%_R1.fq.gz}}_R2.fq.gz" >> {output.r2_out}
        done""" + _LAMBDA_CAT_BLOCK + """

        ## Sum per-chunk stats fieldwise
        awk '{{cnt[$1]+=$2}} END {{
            for (k in cnt) print k"\t"cnt[k]
        }}' {WORKDIR}/{wildcards.sample}/tmp/trim/_out_*_stats.txt \
            | sort -k1,1 > {output.stats}
        """

## One biscuit align call (with -9 to parse <origid>_<XXYY>_<UMI> into CB:Z+RX:Z),
## piped through tag-aware dupsifter -B, sorted by coord, then split into per-cell
## BAMs keyed on CB:Z. Replaces the 9216-cell-per-sample alignment loop.
rule dna_biscuit_align:
    input:
        r1 = WORKDIR + "/{sample}/trim/{sample}_R1.fq.gz",
        r2 = WORKDIR + "/{sample}/trim/{sample}_R2.fq.gz",
    output:
        merged_bam = WORKDIR + "/{sample}/bam_merged/{sample}_merged_dedup.bam",
        merged_bai = WORKDIR + "/{sample}/bam_merged/{sample}_merged_dedup.bam.bai",
        merged_flagstat = WORKDIR + "/{sample}/bam_merged/{sample}_merged_dedup.bam.flagstat",
        dup_stats = WORKDIR + "/{sample}/bam_merged/{sample}_merged_dedup.dupsifter.stat",
        align_txt = WORKDIR + "/{sample}/align_list.txt",
        unmatched = WORKDIR + "/{sample}/bam/UNMATCHED.bam",
    resources:
        mem = "120G",
        time = "96:00:00",
        cpus_per_task = 24,
    params:
        biscuit_index = os.path.join(REF_DIR, ref["REF_BASE"], ref["BISCUIT_INDEX"]),
        ref_fasta     = os.path.join(REF_DIR, ref["REF_BASE"], ref["REF_FASTA"]),
    shell:
        """
        set -xeo pipefail
        ulimit -n 65535
        mkdir -p {WORKDIR}/{wildcards.sample}/bam/ \
                 {WORKDIR}/{wildcards.sample}/bam_merged/

        ## biscuit -9 parses <origid>_<CB>_<UMI> -> emits CB:Z + RX:Z tags (CB is
        ## an 8-char ACGT encoding of the spatial coord; see spatialmeth_trimtag.py).
        ## dupsifter -B uses CB tag for per-cell dedup signature (BS-correct + cell-aware).
        ## PE mode (no -s) because both R1 and R2 are genomic after the barcode/UMI strip.
        biscuit align {params.biscuit_index} -b 1 -9 -@ {resources.cpus_per_task} \
            {input.r2} {input.r1} \
        | {DUPSIFTER} -B --stats-output {output.dup_stats} {params.ref_fasta} - \
        | samtools sort -@ 8 -T {output.merged_bam}_tmp -O bam -o {output.merged_bam} -
        samtools index {output.merged_bam}
        samtools flagstat {output.merged_bam} > {output.merged_flagstat}

        ## Stream-split into per-cell BAMs (one BGZF write per cell, coord order preserved)
        {PYTHON} {SPLIT_BAM_BY_CB} {output.merged_bam} {WORKDIR}/{wildcards.sample}/bam/ --threads 2

        ## Backward-compat rename: the "0000" cell == reads whose barcode missed the whitelist
        if [ -e {WORKDIR}/{wildcards.sample}/bam/0000.bam ]; then
            mv {WORKDIR}/{wildcards.sample}/bam/0000.bam {output.unmatched}
        else
            ## downstream qc_biscuit expects this file; touch a header-only BAM
            samtools view -H {output.merged_bam} | samtools view -b - > {output.unmatched}
        fi

        ## align_list.txt: per-cell coord tags, used by qc_biscuit + pileup as a dependency signal
        find {WORKDIR}/{wildcards.sample}/bam/ -maxdepth 1 -name '[0-9][0-9][0-9][0-9].bam' \
            -printf '%f\n' | sed 's/\\.bam$//' | sort > {output.align_txt}
        """

# CpG methylation pileup: call methylation per barcode BAM, convert VCF to CpG BED,
# merge strands, intersect with reference CpG BED, and pack into yame .cg format.
rule dna_biscuit_pileup:
    input:
        align_txt = WORKDIR + "/{sample}/align_list.txt",
    output:
        cg  = WORKDIR + "/{sample}/pileup/{sample}.cg",
        idx = WORKDIR + "/{sample}/pileup/{sample}.cg.idx",
    resources:
        mem = "120G",
        time = "48:00:00",
        cpus_per_task = 24,
    params:
        ref_fasta = os.path.join(REF_DIR, ref["REF_BASE"], ref["REF_FASTA"]),
        cpg_bed   = os.path.join(REF_DIR, ref["REF_BASE"], ref["CPG_BED"]),
    shell:
        """
        set -xe
        mkdir -p {WORKDIR}/{wildcards.sample}/pileup/
        tmp_pileup={WORKDIR}/{wildcards.sample}/tmp/pileup/
        mkdir -p $tmp_pileup
        for bam in {WORKDIR}/{wildcards.sample}/bam/*.bam; do
            barcode=$(basename $bam .bam)
            out_vcf=$tmp_pileup/$barcode.vcf.gz
            biscuit pileup -m 0 -a 0 -c -u -p -@ {resources.cpus_per_task} {params.ref_fasta} $bam | \
                bgzip -c > $out_vcf
            tabix -p vcf $out_vcf
        done

        vcf2cg() {{
            biscuit vcf2bed -k 1 -t cg $1 | cut -f1-5 | \
                LC_ALL=C sort -k1,1 -k2,2n | \
                biscuit mergecg {params.ref_fasta} - | \
                bedtools intersect -a {params.cpg_bed} -b - -sorted -loj | \
                awk -v OFS="\\t" -F"\\t" -f {workflow.basedir}/../tools/wanding.awk \
                    -e '{{ M=round($7*$8); print M,$8-M;}}' | \
                yame pack -f 3 - ;
        }}
        export -f vcf2cg
        parallel -j {resources.cpus_per_task} \
            'vcf2cg {{}} > '$tmp_pileup'/$(basename {{}} .vcf.gz).cg' \
            ::: $tmp_pileup/*.vcf.gz

        :>{output.cg}
        for cg_file in $tmp_pileup/*.cg; do
            barcode=$(basename $cg_file .cg)
            cat $cg_file >> {output.cg}
            yame index -1 $barcode {output.cg}
        done
        """

# Lambda spike-in: alignment and pileup for bisulfite conversion efficiency estimation.
_lambda_ref      = config["Lambda"]
LAMBDA_REF_FASTA     = os.path.join(REF_DIR, _lambda_ref["REF_BASE"], _lambda_ref["REF_FASTA"])
LAMBDA_BISCUIT_INDEX = os.path.join(REF_DIR, _lambda_ref["REF_BASE"], _lambda_ref["BISCUIT_INDEX"])
LAMBDA_CPG_BED       = os.path.join(REF_DIR, _lambda_ref["REF_BASE"], _lambda_ref["CPG_BED"])

## Lambda alignment inputs depend on protocol:
##   spatialdmt: dedicated barcode-85 reads only (trim/{sample}_Lambda_R{1,2}).
##   smcseq:     no dedicated lambda barcode (Liu repo: zero hits for
##               lambda/J02459/spike-in). Align the FULL tagged fastq to the
##               lambda genome -- any actual spike-in reads will map; mouse
##               reads will mostly fail to map.
if PROTOCOL == "smcseq":
    _LAMBDA_ALIGN_R1 = WORKDIR + "/{sample}/trim/{sample}_R1.fq.gz"
    _LAMBDA_ALIGN_R2 = WORKDIR + "/{sample}/trim/{sample}_R2.fq.gz"
else:
    _LAMBDA_ALIGN_R1 = WORKDIR + "/{sample}/trim/{sample}_Lambda_R1.fq.gz"
    _LAMBDA_ALIGN_R2 = WORKDIR + "/{sample}/trim/{sample}_Lambda_R2.fq.gz"

rule dna_biscuit_align_lambda:
    input:
        r1 = _LAMBDA_ALIGN_R1,
        r2 = _LAMBDA_ALIGN_R2,
    output:
        bam      = WORKDIR + "/{sample}/bam_lambda/{sample}_Lambda.bam",
        bai      = WORKDIR + "/{sample}/bam_lambda/{sample}_Lambda.bam.bai",
        flagstat = WORKDIR + "/{sample}/bam_lambda/{sample}_Lambda.bam.flagstat",
        dup      = WORKDIR + "/{sample}/bam_lambda/{sample}_Lambda.dupsifter.stat",
    resources:
        mem = "80G",
        time = "24:00:00",
        cpus_per_task = 24,
    shell:
        """
        set -xe
        mkdir -p {WORKDIR}/{wildcards.sample}/bam_lambda/
        biscuit align {LAMBDA_BISCUIT_INDEX} -b 1 -@ {resources.cpus_per_task} {input.r2} {input.r1} | \
            dupsifter --stats-output {output.dup} {LAMBDA_REF_FASTA} | \
            samtools sort -T {output.bam}_tmp -O bam -o {output.bam}
        samtools index {output.bam}
        samtools flagstat {output.bam} > {output.flagstat}
        """

# CpG and non-CpG pileup on lambda BAM; allc.bed enables conversion efficiency calculation.
rule dna_biscuit_pileup_lambda:
    input:
        bam = WORKDIR + "/{sample}/bam_lambda/{sample}_Lambda.bam",
        bai = WORKDIR + "/{sample}/bam_lambda/{sample}_Lambda.bam.bai",
    output:
        vcf  = WORKDIR + "/{sample}/tmp/pileup_lambda/{sample}_Lambda.vcf.gz",
        tbi  = WORKDIR + "/{sample}/tmp/pileup_lambda/{sample}_Lambda.vcf.gz.tbi",
        allc = WORKDIR + "/{sample}/tmp/pileup_lambda/{sample}_Lambda_allc.bed",
        cg   = WORKDIR + "/{sample}/pileup/{sample}_Lambda.cg",
    resources:
        mem = "20G",
        time = "24:00:00",
        cpus_per_task = 4,
    shell:
        """
        set -xe
        mkdir -p {WORKDIR}/{wildcards.sample}/tmp/pileup_lambda/ \
                 {WORKDIR}/{wildcards.sample}/pileup/
        biscuit pileup -m 0 -a 0 -c -u -p -@ {resources.cpus_per_task} {LAMBDA_REF_FASTA} {input.bam} | \
            bgzip -c > {output.vcf}
        tabix -p vcf {output.vcf}
        biscuit vcf2bed -t c  -c {output.vcf} > {output.allc}
        biscuit vcf2bed -k 1 -t cg {output.vcf} | cut -f1-5 | \
            LC_ALL=C sort -k1,1 -k2,2n | \
            biscuit mergecg {LAMBDA_REF_FASTA} - | \
            bedtools intersect -a {LAMBDA_CPG_BED} -b - -sorted -loj | \
            awk -v OFS="\\t" -F"\\t" -f {workflow.basedir}/../tools/wanding.awk \
                -e '{{ M=round($7*$8); print M,$8-M;}}' | \
            yame pack -f 3 - > {output.cg}
        """

################################################################################
# RNA Pipeline Rules
################################################################################

bbduk        = require_config("BBDUK")
STAR_REF_DIR = os.path.join(REF_DIR, GENOME_FOR_PATH, "STAR")

# Keep only R2 reads that contain the spatial primer sequence (identifies valid library molecules)
rule rna_filter_primer:
    input:
        in1 = lambda wildcards: get_fastq(wildcards, "RNA_1"),
        in2 = lambda wildcards: get_fastq(wildcards, "RNA_2"),
    output:
        out1 = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R1_filtered_primer.fastq.gz",
        out2 = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R2_filtered_primer.fastq.gz",
    resources:
        mem = "20G",
        time = "12:00:00",
        cpus_per_task = 12,
    shell:
        """
        mkdir -p {WORKDIR}/{wildcards.sample}/tmp/rna_processed/ \
                 {WORKDIR}/{wildcards.sample}/rna_bbduk/
        {bbduk} \
        in1={input.in1} in2={input.in2} \
        outm1={output.out1} outm2={output.out2} \
        k=22 mm=f rcomp=f restrictleft=30 skipr1=t hdist=2 \
        stats={WORKDIR}/{wildcards.sample}/rna_bbduk/{wildcards.sample}_stats.primer.txt \
        threads={resources.cpus_per_task} \
        literal=CAAGCGTTGGCTTCTCGCATCT
        """

# Keep reads containing linker 1 sequence in R2 (marks the BC1/BC2 junction)
rule rna_filter_L1:
    input:
        in1 = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R1_filtered_primer.fastq.gz",
        in2 = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R2_filtered_primer.fastq.gz",
    output:
        out1 = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R1_filtered_linker1.fastq.gz",
        out2 = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R2_filtered_linker1.fastq.gz",
    resources:
        mem = "20G",
        time = "12:00:00",
        cpus_per_task = 12,
    shell:
        """
        {bbduk} \
        in1={input.in1} in2={input.in2} \
        outm1={output.out1} outm2={output.out2} \
        k=30 mm=f rcomp=f restrictleft=108 skipr1=t hdist=3 \
        stats={WORKDIR}/{wildcards.sample}/rna_bbduk/{wildcards.sample}_stats.linker1.txt \
        threads={resources.cpus_per_task} \
        literal=GTGGCCGATGTTTCGCATCGGCGTACGACT
        """

# Keep reads containing linker 2 sequence in R2 (marks the BC2/UMI junction)
rule rna_filter_L2:
    input:
        in1 = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R1_filtered_linker1.fastq.gz",
        in2 = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R2_filtered_linker1.fastq.gz",
    output:
        out1 = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R1_filtered_linker2.fastq",
        out2 = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R2_filtered_linker2.fastq.gz",
    resources:
        mem = "20G",
        time = "12:00:00",
        cpus_per_task = 12,
    shell:
        """
        {bbduk} \
        in1={input.in1} in2={input.in2} \
        outm1={output.out1} outm2={output.out2} \
        k=30 mm=f rcomp=f restrictleft=70 skipr1=t hdist=3 \
        stats={WORKDIR}/{wildcards.sample}/rna_bbduk/{wildcards.sample}_stats.linker2.txt \
        threads={resources.cpus_per_task} \
        literal=ATCCACGTGCTTGAGAGGCCAGAGCATTCG
        """

# Extract barcode+UMI from fixed positions in R2 and reformat into STARsolo-compatible read
rule rna_fq_process:
    input:
        WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R2_filtered_linker2.fastq.gz",
    output:
        WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R2_processed.fastq",
    resources:
        mem = "8G",
        time = "4:00:00",
        cpus_per_task = 1,
    shell:
        """
        {PYTHON} {workflow.basedir}/../tools/fastq_process.py --input {input} --output {output}
        """

# Align RNA reads and quantify gene expression per spatial barcode using STARsolo
rule rna_star_solo:
    input:
        read_BC  = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R2_processed.fastq",
        read_Seq = WORKDIR + "/{sample}/tmp/rna_processed/{sample}_R1_filtered_linker2.fastq",
        wl       = os.path.join(BARCODES_DIR, "RNA_whitelist_singlecol.txt"),
    output:
        sam = WORKDIR + "/{sample}/rna_STAR/Aligned.out.sam",
        log = WORKDIR + "/{sample}/rna_STAR/Log.final.out",
    resources:
        mem = "100G",
        time = "24:00:00",
        cpus_per_task = 24,
    shell:
        """
        if command -v module >/dev/null 2>&1; then module load STAR || true; fi
        mkdir -p {WORKDIR}/{wildcards.sample}/rna_STAR/
        STAR --runThreadN {resources.cpus_per_task} \
            --genomeDir {STAR_REF_DIR} \
            --readFilesIn {input.read_Seq} {input.read_BC} \
            --soloType CB_UMI_Simple \
            --soloCBwhitelist {input.wl} \
            --soloFeatures GeneFull \
            --outFileNamePrefix {WORKDIR}/{wildcards.sample}/rna_STAR/

        """

################################################################################
# QC Rules
# Run after preprocessing: snakemake --profile profiles/local_HPC -- qc
################################################################################

# Run BISCUIT's QC.sh on every per-barcode BAM (including UNMATCHED) using its pileup VCF.
# Results are merged into a single set of tables for MultiQC.
## Biscuit 1.8 lives in the conda env at conda_2026/envs/biscuit; prepend so
## the bare `biscuit` call inside spatialmeth_qc.sh picks up 1.8 over the
## cluster-default 1.6.1-dev in /mnt/isilon/zhoulab/labbin.
BISCUIT_BIN = config.get("BISCUIT_BIN",
    "/mnt/isilon/zhoulab/labsoftware/anaconda/conda_2026/envs/biscuit/bin")

rule qc_biscuit:
    input:
        align_txt = WORKDIR + "/{sample}/align_list.txt",
        unmatched = WORKDIR + "/{sample}/bam/UNMATCHED.bam",
        cg        = WORKDIR + "/{sample}/pileup/{sample}.cg",
    output:
        flag = WORKDIR + "/{sample}/qc/biscuit_qc/.done",
    resources:
        mem = "32G",
        time = "96:00:00",
        cpus_per_task = 24,
    params:
        ref_fasta = os.path.join(REF_DIR, ref["REF_BASE"], ref["REF_FASTA"]),
        assets    = os.path.join(REF_DIR, ref["REF_BASE"], ref["BISCUIT_QCASSET"]),
    shell:
        """
        set -xe
        export PATH={BISCUIT_BIN}:$PATH
        mkdir -p {WORKDIR}/{wildcards.sample}/qc/biscuit_qc/

        QC={workflow.basedir}/../tools/spatialmeth_qc.sh
        parallel -j {resources.cpus_per_task} \
            "$QC -o {WORKDIR}/{wildcards.sample}/qc/biscuit_qc/ \
                --vcf {WORKDIR}/{wildcards.sample}/tmp/pileup/{{}}.vcf.gz \
                --cg-file {input.cg} \
                --barcode {{}} \
                {params.assets} \
                {params.ref_fasta} \
                {wildcards.sample}_{{}} \
                {WORKDIR}/{wildcards.sample}/bam/{{}}.bam" \
            < {input.align_txt}
        $QC -o {WORKDIR}/{wildcards.sample}/qc/biscuit_qc/ \
            --vcf {WORKDIR}/{wildcards.sample}/tmp/pileup/UNMATCHED.vcf.gz \
            --cg-file {input.cg} \
            --barcode UNMATCHED \
            {params.assets} \
            {params.ref_fasta} \
            {wildcards.sample}_UNMATCHED \
            {input.unmatched}
        touch {output.flag}
        """

rule qc_biscuit_aggregate:
    input:
        flag          = WORKDIR + "/{sample}/qc/biscuit_qc/.done",
        spatial_counts = WORKDIR + "/{sample}/qc/table/{sample}_spatial_barcode_counts.tsv",
        align_txt     = WORKDIR + "/{sample}/align_list.txt",
    output:
        flag = WORKDIR + "/{sample}/qc/biscuit_qc_merged/.done",
    resources:
        mem = "16G",
        time = "4:00:00",
        cpus_per_task = 1,
    shell:
        """
        {PYTHON} {workflow.basedir}/../tools/aggregate_biscuit_qc.py \
            --input-dir      {WORKDIR}/{wildcards.sample}/qc/biscuit_qc/ \
            --output-dir     {WORKDIR}/{wildcards.sample}/qc/biscuit_qc_merged/ \
            --sample         {wildcards.sample} \
            --align-txt      {input.align_txt} \
            --spatial-counts {input.spatial_counts}
        touch {output.flag}
        """

FEATURE_DIR    = os.path.join(REF_DIR, GENOME_FOR_PATH, "features")
FEATURE_CM_DIR = os.path.join(REF_DIR, GENOME_FOR_PATH, f"KYCGKB_{GENOME_FOR_PATH}")
CHROMHMM_CM    = os.path.join(REF_DIR, ref["REF_BASE"], ref["CHROMHMM_CM"])
if GENOME_FOR_PATH == "hg38":
    FEATS = ["ChromHMM.20220303", "Win100k.20220228", "Chromosome.20221129"]
else:
    FEATS = ["ChromHMM.20220414", "Win100k.20220228", "Win1m.20230709", "Chromosome.20221129"]

# Per-barcode read counts, spatial mapping, and QC heatmap plots
## Per-cell read counts + spatial heatmaps from the merged deduped BAM (one
## pysam pass; aggregates per CB:Z tag, decodes back to (X, Y) via cb_codec).
rule qc_barcode_summary:
    input:
        merged_bam = WORKDIR + "/{sample}/bam_merged/{sample}_merged_dedup.bam",
    output:
        spatial_counts = WORKDIR + "/{sample}/qc/table/{sample}_spatial_barcode_counts.tsv",
        plots_done     = WORKDIR + "/{sample}/qc/plots/.done",
    resources:
        mem = "12G",
        cpus_per_task = 4,
    shell:
        """
        {PYTHON} {workflow.basedir}/../tools/barcode_summary.py \
            --merged-bam {input.merged_bam} \
            --sample     {wildcards.sample} \
            --table-dir  {WORKDIR}/{wildcards.sample}/qc/table/ \
            --plots-dir  {WORKDIR}/{wildcards.sample}/qc/plots/ \
            --grid-x     {GRID_X} \
            --grid-y     {GRID_Y}
        touch {output.plots_done}
        """

# MultiQC aggregation + self-contained HTML report
rule qc_report:
    input:
        star_log       = lambda wc: fWORKDIR + "/{wc.sample}/rna_STAR/Log.final.out"
                         if wc.sample in RNA_SAMPLES else [],
        biscuit_merged = WORKDIR + "/{sample}/qc/biscuit_qc_merged/.done",
        spatial_counts = WORKDIR + "/{sample}/qc/table/{sample}_spatial_barcode_counts.tsv",
        trim_stats     = WORKDIR + "/{sample}/trim/{sample}_trim_stats.txt",
        cg             = WORKDIR + "/{sample}/pileup/{sample}.cg",
        plots_done     = WORKDIR + "/{sample}/qc/plots/.done",
    output:
        multiqc      = WORKDIR + "/{sample}/qc/html/multiqc_report.html",
        multiqc_data = directory(WORKDIR + "/{sample}/qc/html/multiqc_report_data"),
        report       = WORKDIR + "/{sample}/qc/html/qc_report.html",
        stats_mqc    = WORKDIR + "/{sample}/qc/table/{sample}_stats_mqc.tsv",
        chromhmm_sum = WORKDIR + "/{sample}/qc/table/{sample}_chromhmm_summary.tsv",
    resources:
        mem = "12G",
        cpus_per_task = 4,
    shell:
        """
        mkdir -p {WORKDIR}/{wildcards.sample}/qc/html/
        
        # Explicitly aggregate methylation levels for TssA and Tx
        yame rowop -o musum {input.cg} | \
            yame summary -m {CHROMHMM_CM} - > {output.chromhmm_sum}

        {PYTHON} {workflow.basedir}/../tools/write_stats_mqc.py \
            --trim-stats       {input.trim_stats} \
            --spatial-counts   {input.spatial_counts} \
            --chromhmm-summary {output.chromhmm_sum} \
            --sample           {wildcards.sample} \
            --output-dir       {WORKDIR}/{wildcards.sample}/qc/table/
        RNA_DIRS=""
        if [[ -n "{input.star_log}" ]]; then
            RNA_DIRS=WORKDIR + "/{wildcards.sample}/rna_STAR/ {WORKDIR}/{wildcards.sample}/rna_bbduk/"
        fi
        {PYTHON} -m multiqc \
            $RNA_DIRS \
            {WORKDIR}/{wildcards.sample}/qc/biscuit_qc_merged/ \
            {WORKDIR}/{wildcards.sample}/qc/table/ \
            --outdir {WORKDIR}/{wildcards.sample}/qc/html/ \
            --filename multiqc_report.html \
            --force \
            --cl-config "sample_names_replace: {{rna_STAR: {wildcards.sample}}}"
        {PYTHON} {workflow.basedir}/../tools/generate_html_report.py \
            --spatial-counts {input.spatial_counts} \
            --plots-dir      {WORKDIR}/{wildcards.sample}/qc/plots/ \
            --sample         {wildcards.sample} \
            --multiqc-html   {output.multiqc} \
            --output         {output.report}
        """

# Per-barcode mean methylation summarized over genomic features (ChromHMM, windows, chromosomes)
rule feature_mean:
    input:
        cg   = WORKDIR + "/{sample}/pileup/{sample}.cg",
        feat = os.path.join(FEATURE_DIR, "{feat}.bed.gz"),
    output:
        txt = WORKDIR + "/{sample}/qc/features/{feat}.txt.gz",
    resources:
        mem = "120G",
        time = "6:00:00",
        cpus_per_task = 24,
    shell:
        """
        set -xe
        tmp={WORKDIR}/{wildcards.sample}/qc/tmp/features_{wildcards.feat}/
        rm -rf $tmp && mkdir -p $tmp
        cut -f1 {input.cg}.idx | parallel -j {resources.cpus_per_task} \
            'yame subset {input.cg} {{}} | \
                yame summary -q {{}} -m {FEATURE_CM_DIR}/{wildcards.feat}.cm - | \
                gzip -c > '"$tmp"'/{{}}.txt.gz'
        zcat $tmp/*.txt.gz | awk 'NR==1 || $1 != "QFile"' | gzip -c > {output.txt}
        rm -rf $tmp
        """


# QC target: spatial HTML report + MultiQC + feature-level methylation summaries
rule qc:
    input:
        expand(WORKDIR + "/{sample}/qc/html/qc_report.html", sample=SAMPLES),
        expand(WORKDIR + "/{sample}/qc/features/{feat}.txt.gz", sample=SAMPLES, feat=FEATS),

